# OpenAI-compatible chat-completions API for the ToolSelf agent.
export MAIN_LLM_API_KEY="..."
export MAIN_LLM_API_BASE_URL="https://example.com/v1"
export MAIN_LLM_MODEL="Qwen/Qwen3-14B"
export MAIN_LLM_MAX_TOKENS="4096"

# Optional separate model for webpage summarization. Defaults to MAIN_*.
export VISIT_LLM_API_KEY="${MAIN_LLM_API_KEY}"
export VISIT_LLM_API_BASE_URL="${MAIN_LLM_API_BASE_URL}"
export VISIT_LLM_MODEL="${MAIN_LLM_MODEL}"
export VISIT_LLM_MAX_TOKENS="4096"

# Optional separate models for file analysis. Defaults to MAIN_* when unset.
export FILE_ANALYZER_API_KEY="${MAIN_LLM_API_KEY}"
export FILE_ANALYZER_API_BASE_URL="${MAIN_LLM_API_BASE_URL}"
export FILE_ANALYZER_TEXT_MODEL="Qwen/Qwen3-30B-A3B"
export FILE_ANALYZER_VISION_MODEL="Qwen/Qwen3-VL-30B-A3B-Instruct"

# LLM-as-judge configuration.
export JUDGE_API_KEY="..."
export JUDGE_BASE_URL="https://example.com/v1"
export JUDGE_MODEL="Qwen/Qwen2.5-72B-Instruct"

# Web tools.
export JINA_KEY="..."
export JINA_READER_URL="https://r.jina.ai/"
export SEARX_HOST="http://localhost:8888"
export SEARX_LANGUAGE="en-US"

# Dataset root used by configs/*.example.json.
export DATA_ROOT="/path/to/datasets"

# ToolSelf runtime limits.
export MAX_LLM_CALL_PER_RUN="200"
